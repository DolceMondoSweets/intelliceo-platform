# Supabase — Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API — same key as the existing dolce-mondo-atlas app
ANTHROPIC_API_KEY=

# Sentry — DSN from your Sentry project's Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional — only needed for source map upload during production builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
